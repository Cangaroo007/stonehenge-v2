# Copy this file to .env and fill in real values.
# Never commit .env to git.

# Core app/database
DATABASE_URL="postgresql://..."
DATABASE_PUBLIC_URL="postgresql://..."
JWT_SECRET="generate-a-strong-random-secret"

# AI drawing interpretation
ANTHROPIC_API_KEY="sk-ant-..."

# Cloudflare R2 drawing/file storage
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET_NAME="stonehenge-drawings"
# Use either R2_ENDPOINT or R2_ACCOUNT_ID.
R2_ENDPOINT="https://...r2.cloudflarestorage.com"
R2_ACCOUNT_ID="..."

# Distance calculations / maps
GOOGLE_MAPS_API_KEY="..."
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="..."

# Optional defaults/diagnostics
COMPANY_ADDRESS="20 Hitech Drive, KUNDA PARK Queensland 4556, Australia"
NEXT_PUBLIC_BUILD_ID="dev"
LOG_LEVEL="info"
